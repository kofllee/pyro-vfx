{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Tests looping emitter evaluation: emitter.normalized_age and emitter.local_age must reset every loop."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 180
  },
  "emitters": [
    {
      "id": "looping_pulse_smoke",
      "emitter_lifetime": {
        "mode": "looping",
        "delay_ticks": 0,
        "active_ticks": 20,
        "sleep_ticks": 20,
        "loops": 4
      },
      "spawn_amount": {
        "mode": "steady",
        "rate": "8 + emitter.normalized_age * 52",
        "max_particles": 300
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": "0.05 + emitter.normalized_age * 3",
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "1000"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0",
          "acceleration": [0, 0.25, 0],
          "linear_drag": 2.0
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, "particle.random * 360", 0],
          "angular_velocity": [0, "-60 + particle.random * 120", 0],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.5
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera_horizontal",
        "environment_lighting": true,
        "material": {
          "blend_mode": "alpha"
        },
        "sprite": {
          "texture": "minecraft:textures/particle/generic_0.png"
        },
        "color": [
          "0.25 + emitter.normalized_age * 0.35",
          "0.25 + emitter.normalized_age * 0.35",
          "0.25 + emitter.normalized_age * 0.35",
          "1.0"
        ],
        "scale": [
          "0.5",
          "0.5",
          1.0
        ]
      }
    }
  ]
}