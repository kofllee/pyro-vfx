{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Debug effect: particle color is based on current velocity direction."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 100
  },
  "emitters": [
    {
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": 1000
      },
      "offset": [0, 1, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 1.0,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": 70
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "5",
          "acceleration": [0, 0, 0],
          "linear_drag": 0.1
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, 0, 90],
          "angular_velocity": [0, 90, 90],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 0.8
        }
      },
      "render": {
        "type": "sprite",
        "sprite": {
          "texture": "minecraft:textures/particle/generic_0.png"
        },
        "color": [
          "0.5 + particle.vel.x * 18.0",
          "0.5 + particle.vel.y * 18.0",
          "0.5 + particle.vel.z * 18.0",
          "1.0 - particle.normalized_age"
        ],
        "alpha": "particle.normalized_age",
        "size": "0.45 + particle.speed * 9.0"
      }
    },
