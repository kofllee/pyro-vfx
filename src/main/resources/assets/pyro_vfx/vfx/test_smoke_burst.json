{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "2D sprite particle render test."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 60
  },
  "emitters": [
    {
      "id": "sprite_test",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": 16
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.15,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "35 + particle.random * 25"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.35 + particle.random * 0.8",
          "acceleration": [0, 0.25, 0],
          "linear_drag": 1.4
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, "particle.random * 360", 0],
          "angular_velocity": [0, "-60 + particle.random * 120", 0],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.5
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera",
        "environment_lighting": true,
        "sprite": {
          "texture": "pyro_vfx:textures/vfx/smoke.png",
          "blend_mode": "additive"
        },
        "color": [
          "0.35 + particle.random * 0.08",
          "0.35 + particle.random * 0.08",
          "0.35 + particle.random * 0.08",
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.18 + particle.normalized_age * 0.75",
          "0.18 + particle.normalized_age * 0.75",
          1.0
        ]
      }
    }
  ]
}