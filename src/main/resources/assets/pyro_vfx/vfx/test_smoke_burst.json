{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Basic vanilla block model particle test."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 80
  },
  "emitters": [
    {
      "id": "model_chunks",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": 12
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.25,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "35 + particle.random * 35"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.8 + particle.random * 1.2",
          "acceleration": [0, -1.2, 0],
          "linear_drag": 0.7
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [
            "particle.random * 360",
            "particle.random * 360",
            "particle.random * 360"
          ],
          "angular_velocity": [
            "-180 + particle.random * 360",
            "-180 + particle.random * 360",
            "-180 + particle.random * 360"
          ],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.5
        }
      },
      "render": {
        "type": "model",
        "environment_lighting": true,
        "material": {
          "blend_mode": "alpha"
        },
        "model": {
          "source": "custom",
          "model": "pyro_vfx:vfx/stone_chunk",
          "render_layer": "translucent"
        },
        "color": [
          "1",
          "1",
          "1",
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.15 + particle.normalized_age * 0.25",
          "0.15 + particle.normalized_age * 0.25",
          "0.15 + particle.normalized_age * 0.25"
        ]
      }
    }
  ]
}