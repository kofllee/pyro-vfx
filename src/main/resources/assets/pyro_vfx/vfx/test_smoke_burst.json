{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Runtime expression test."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": "20 + 40"
  },
  "emitters": [
    {
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 60
      },
      "spawn_amount": {
        "mode": "steady",
        "rate": "5 + emitter.age * 10",
        "max_particles": 100
      },
      "spawn_shape": {
        "type": "sphere",
        "offset": [0, 0.2, 0],
        "radius": "0.2 + emitter.normalized_age * 5.0",
        "edge_thickness": 0.0
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.02 + particle.random * 0.05",
          "acceleration": [0, 0, 0],
          "linear_drag": 0
        }
      },
      "render": {
        "type": "minecraft_particle",
        "minecraft_particle": {
          "particle": "minecraft:smoke"
        }
      }
    }
  ]
}