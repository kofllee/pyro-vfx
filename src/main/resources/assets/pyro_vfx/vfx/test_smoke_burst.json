{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "UV animation test using vanilla Minecraft fire texture."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 100
  },
  "emitters": [
    {
      "id": "fire_uv_test",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 100
      },
      "spawn_amount": {
        "mode": "steady",
        "rate": 8,
        "max_particles": 80
      },
      "offset": [0, 0.1, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.08,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "18 + particle.random * 12"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "up",
          "speed": "0.25 + particle.random * 0.25",
          "acceleration": [0, 0.15, 0],
          "linear_drag": 1.6
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, 0, 0],
          "angular_velocity": [0, 0, 0],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 2.0
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera",
        "environment_lighting": false,
        "material": {
          "blend_mode": "alpha"
        },
        "sprite": {
          "texture": "minecraft:textures/block/fire_0.png",
          "uv": {
            "mode": "animated",
            "texture_size": [16, 512, 0],
            "uv_start": [0, 0, 0],
            "uv_size": [16, 16, 0],
            "uv_step": [0, 16, 0],
            "frame_count": 32,
            "fps": "16 + particle.random * 8",
            "stretch_to_lifetime": true,
            "loop": true,
            "random_start_frame": true
          }
        },
        "color": [
          1.0,
          1.0,
          1.0,
          1.0
        ],
        "scale": [
          "0.18 + particle.normalized_age * 0.22",
          "0.28 + particle.normalized_age * 0.32",
          1.0
        ]
      }
    }
  ]
}