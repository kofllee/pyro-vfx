{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Test entity model particle without color tint."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 100
  },
  "emitters": [
    {
      "id": "entity_particles",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": 4
      },
      "offset": [0, 1.2, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.4,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "65 + particle.random * 25"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.35 + particle.random * 0.55",
          "acceleration": [0, -0.6, 0],
          "linear_drag": 0.8
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [
            0,
            "particle.random * 360",
            0
          ],
          "angular_velocity": [
            0,
            "-90 + particle.random * 180",
            0
          ],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.0
        }
      },
      "render": {
        "type": "model",
        "environment_lighting": true,
        "model": {
          "source": "entity",
          "model": "minecraft:chicken",
          "render_layer": "solid"
        },
        "scale": [
          "0.18 + particle.random * 0.05",
          "0.18 + particle.random * 0.05",
          "0.18 + particle.random * 0.05"
        ]
      }
    }
  ]
}