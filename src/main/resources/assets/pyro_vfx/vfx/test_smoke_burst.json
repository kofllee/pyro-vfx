{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Parameter test: smoke amount, speed and color are driven by param.*"
  },
  "parameters": {
    "power": 10,
    "red": 1.0,
    "green": 0.45,
    "blue": 0.12
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 60
  },
  "emitters": [
    {
      "id": "param_smoke",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": "8 + param.power * 12"
      },
      "offset": [0, 0.2, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": "0.1 + param.power * 0.05",
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "30 + param.power * 12"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.4 + param.power * 0.35",
          "acceleration": [0, 0.35, 0],
          "linear_drag": 1.4
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, "particle.random * 360", 0],
          "angular_velocity": [0, "-40 + particle.random * 80", 0],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.2
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera_horizontal",
        "environment_lighting": true,
        "material": {
          "blend_mode": "alpha"
        },
        "sprite": {
          "texture": "pyro_vfx:textures/vfx/smoke.png"
        },
        "color": [
          "param.red",
          "param.green",
          "param.blue",
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.2 + particle.normalized_age * param.power",
          "0.2 + particle.normalized_age * param.power",
          1.0
        ]
      }
    }
  ]
}