{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Additive custom model ember burst test with particle count parameter."
  },
  "parameters": {
    "particle_count": 18
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 50
  },
  "emitters": [
    {
      "id": "additive_model_embers",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": "param.particle_count"
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.08,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "18 + particle.random * 18"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.8 + particle.random * 1.4",
          "acceleration": [0, -1.2, 0],
          "linear_drag": 1.8
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [
            "particle.random * 360",
            "particle.random * 360",
            "particle.random * 360"
          ],
          "angular_velocity": [
            "-180 + particle.random * 360",
            "-180 + particle.random * 360",
            "-180 + particle.random * 360"
          ],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 2.0
        }
      },
      "render": {
        "type": "model",
        "environment_lighting": false,
        "model": {
          "source": "custom",
          "model": "pyro_vfx:vfx/ember_cube",
          "render_layer": "additive"
        },
        "color": [
          1.0,
          "0.45 + particle.random * 0.25",
          0.08,
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.06 + particle.random * 0.05",
          "0.06 + particle.random * 0.05",
          "0.06 + particle.random * 0.05"
        ]
      }
    }
  ]
}