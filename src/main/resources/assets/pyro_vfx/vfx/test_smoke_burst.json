{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Test block model particle with tinted oak leaves block_state."
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 90
  },
  "emitters": [
    {
      "id": "leaf_fragments",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 1
      },
      "spawn_amount": {
        "mode": "instant",
        "amount": 16
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.35,
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "45 + particle.random * 35"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.45 + particle.random * 0.85",
          "acceleration": [0, -0.85, 0],
          "linear_drag": 1.4
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [
            "particle.random * 360",
            "particle.random * 360",
            "particle.random * 360"
          ],
          "angular_velocity": [
            "-90 + particle.random * 180",
            "-140 + particle.random * 280",
            "-90 + particle.random * 180"
          ],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.8
        }
      },
      "render": {
        "type": "model",
        "environment_lighting": true,
        "model": {
          "source": "block",
          "model": "minecraft:oak_leaves",
          "block_state": "minecraft:oak_leaves[distance=1,persistent=true,waterlogged=false]",
          "render_layer": "cutout"
        },
        "color": [1.0, 0.0, 0.0, "1.0 - particle.normalized_age"],
        "scale": [
          "0.12 + particle.random * 0.08",
          "0.12 + particle.random * 0.08",
          "0.12 + particle.random * 0.08"
        ]
      }
    }
  ]
}