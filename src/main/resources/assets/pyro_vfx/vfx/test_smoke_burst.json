{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "set_param test: smoke changes power at timeline tick."
  },
  "parameters": {
    "power": 0.4
  },
  "lifetime": {
    "mode": "once",
    "delay_ticks": 0,
    "active_ticks": 80
  },
  "events": {
    "boost_power": {
      "type": "set_param",
      "param": "power",
      "value": 2.5
    }
  },
  "triggers": [
    {
      "type": "timeline",
      "time_ticks": 30,
      "event": "boost_power"
    }
  ],
  "emitters": [
    {
      "id": "smoke",
      "emitter_lifetime": {
        "mode": "once",
        "delay_ticks": 0,
        "active_ticks": 80
      },
      "spawn_amount": {
        "mode": "steady",
        "rate": "6 + param.power * 16",
        "max_particles": 160
      },
      "offset": [0, 0.2, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": "0.08 + param.power * 0.04",
        "edge_thickness": 0.0
      },
      "particle_lifetime": {
        "max_age_ticks": "25 + param.power * 10"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "outward",
          "speed": "0.25 + param.power * 0.25",
          "acceleration": [0, 0.35, 0],
          "linear_drag": 1.5
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, "particle.random * 360", 0],
          "angular_velocity": [0, "-40 + particle.random * 80", 0],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.0
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera_horizontal",
        "environment_lighting": true,
        "material": {
          "blend_mode": "alpha"
        },
        "sprite": {
          "texture": "minecraft:textures/particle/generic_0.png"
        },
        "color": [
          0.35,
          0.35,
          0.35,
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.15 + particle.normalized_age * param.power",
          "0.15 + particle.normalized_age * param.power",
          1.0
        ]
      }
    }
  ]
}