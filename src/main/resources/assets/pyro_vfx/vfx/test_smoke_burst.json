{
  "format": "pyro_vfx:1",
  "metadata": {
    "author": "kofllee",
    "description": "Render material matrix test: alpha/additive, depth_write true/false, environment_lighting true/false."
  },
  "lifetime": {
    "mode": "looping",
    "delay_ticks": 0,
    "active_ticks": 200,
    "sleep_ticks": 0,
    "loops": 0
  },
  "emitters": [
    {
      "emitter_lifetime": {
        "mode": "looping",
        "delay_ticks": 0,
        "active_ticks": 200,
        "sleep_ticks": 0,
        "loops": 0
      },
      "spawn_amount": {
        "mode": "steady",
        "rate": 12,
        "max_particles": 120
      },
      "offset": [0, 1.0, 0],
      "spawn_shape": {
        "type": "sphere",
        "radius": 0.12,
        "edge_thickness": 1.0
      },
      "particle_lifetime": {
        "max_age_ticks": "35 + particle.random * 20"
      },
      "motion": {
        "mode": "dynamic",
        "dynamic": {
          "direction": "up",
          "speed": "0.75 + particle.random * 0.25",
          "acceleration": [
            "(particle.random - 0.5) * 0.08",
            0.12,
            "(particle.random - 0.5) * 0.08"
          ],
          "linear_drag": 1.25
        }
      },
      "rotation": {
        "mode": "dynamic",
        "dynamic": {
          "start_rotation": [0, 0, "particle.random * 360"],
          "angular_velocity": [0, 0, "-45 + particle.random * 90"],
          "angular_acceleration": [0, 0, 0],
          "angular_drag": 1.2
        }
      },
      "render": {
        "type": "sprite",
        "facing": "camera",
        "environment_lighting": false,
        "material": {
          "blend_mode": "alpha"
        },
        "sprite": {
          "texture": "minecraft:textures/particle/generic_0.png"
        },
        "color": [
          1.0,
          "0.45 + particle.random * 0.25",
          0.08,
          "1.0 - particle.normalized_age"
        ],
        "scale": [
          "0.35 + particle.normalized_age * 0.35",
          "0.65 + particle.normalized_age * 0.55",
          1.0
        ]
      }
    }
  ]
}